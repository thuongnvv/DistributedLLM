[
  {
    "node_id": "node_a",
    "points": [
      {
        "point_id": "node_a:0:5d0c5bf0",
        "text": "Common symptoms include coughing, fever, and loss of smell and taste.",
        "citations": [
          "doc1_covid19.txt:chunk_00011"
        ]
      },
      {
        "point_id": "node_a:1:7fd6c357",
        "text": "Symptoms may also include headaches, nasal congestion, and runny nose.",
        "citations": [
          "doc1_covid19.txt:chunk_00011"
        ]
      },
      {
        "point_id": "node_a:2:adf194be",
        "text": "Muscle pain, sore throat, and diarrhea are less common symptoms.",
        "citations": [
          "doc1_covid19.txt:chunk_00011"
        ]
      },
      {
        "point_id": "node_a:3:e4cdca4f",
        "text": "Breathing difficulties can occur in moderate to severe cases.",
        "citations": [
          "doc1_covid19.txt:chunk_00011"
        ]
      },
      {
        "point_id": "node_a:4:c1e180b5",
        "text": "Fever, fatigue, cough, and breathing difficulties are often reported.",
        "citations": [
          "doc1_covid19.txt:chunk_00001"
        ]
      },
      {
        "point_id": "node_a:5:7e714290",
        "text": "Loss of taste combined with loss of smell is reported in many cases.",
        "citations": [
          "doc1_covid19.txt:chunk_00012"
        ]
      },
      {
        "point_id": "node_a:6:fc3bc909",
        "text": "A respiratory symptom cluster includes cough, sputum, and fever.",
        "citations": [
          "doc1_covid19.txt:chunk_00012"
        ]
      },
      {
        "point_id": "node_a:7:68d92209",
        "text": "Musculoskeletal symptoms include muscle and joint pain, headache, and fatigue.",
        "citations": [
          "doc1_covid19.txt:chunk_00012"
        ]
      },
      {
        "point_id": "node_a:8:2c4f282d",
        "text": "Digestive symptoms can include abdominal pain, vomiting, and diarrhea.",
        "citations": [
          "doc1_covid19.txt:chunk_00012"
        ]
      }
    ]
  },
  {
    "node_id": "node_b",
    "points": [
      {
        "point_id": "node_b:0:701a6d86",
        "text": "COVID-19 symptoms often show up 2 to 14 days after contact with the virus.",
        "citations": [
          "doc2_covid19.txt:chunk_00002"
        ]
      },
      {
        "point_id": "node_b:1:f59e055b",
        "text": "Common symptoms include congestion, runny nose, or sore throat.",
        "citations": [
          "doc2_covid19.txt:chunk_00002"
        ]
      },
      {
        "point_id": "node_b:2:1e357a9c",
        "text": "Other symptoms include dry cough and shortness of breath.",
        "citations": [
          "doc2_covid19.txt:chunk_00002"
        ]
      },
      {
        "point_id": "node_b:3:e4a275c4",
        "text": "Loss of taste or smell is a common symptom of COVID-19.",
        "citations": [
          "doc2_covid19.txt:chunk_00002"
        ]
      },
      {
        "point_id": "node_b:4:36e16d9f",
        "text": "Extreme tiredness, called fatigue, is another symptom.",
        "citations": [
          "doc2_covid19.txt:chunk_00002"
        ]
      },
      {
        "point_id": "node_b:5:db38ccd4",
        "text": "Digestive symptoms such as upset stomach, vomiting, or diarrhea can occur.",
        "citations": [
          "doc2_covid19.txt:chunk_00002"
        ]
      },
      {
        "point_id": "node_b:6:f6096ecf",
        "text": "Pain, including headaches and body or muscle aches, is common.",
        "citations": [
          "doc2_covid19.txt:chunk_00002"
        ]
      },
      {
        "point_id": "node_b:7:29116607",
        "text": "Fever or chills are also symptoms of COVID-19.",
        "citations": [
          "doc2_covid19.txt:chunk_00002"
        ]
      },
      {
        "point_id": "node_b:8:16444ca0",
        "text": "Dizziness and dry mouth may indicate dehydration related to COVID-19.",
        "citations": [
          "doc2_covid19.txt:chunk_00006"
        ]
      },
      {
        "point_id": "node_b:9:b20b0d3e",
        "text": "New confusion and trouble staying awake are serious symptoms to watch for.",
        "citations": [
          "doc2_covid19.txt:chunk_00005"
        ]
      }
    ]
  },
  {
    "node_id": "node_c",
    "points": [
      {
        "point_id": "node_c:0:4831f02a",
        "text": "The most common symptoms are fever, cough, and tiredness.",
        "citations": [
          "doc3_covid19.txt:chunk_00001"
        ]
      },
      {
        "point_id": "node_c:1:6fdc6079",
        "text": "Other symptoms can include shortness of breath and chest pain or pressure.",
        "citations": [
          "doc3_covid19.txt:chunk_00001"
        ]
      },
      {
        "point_id": "node_c:2:2c0375cb",
        "text": "Muscle or body aches, headache, and loss of taste or smell are also common.",
        "citations": [
          "doc3_covid19.txt:chunk_00001"
        ]
      },
      {
        "point_id": "node_c:3:a3f30eb2",
        "text": "Confusion, sore throat, and congestion or runny nose may occur.",
        "citations": [
          "doc3_covid19.txt:chunk_00001"
        ]
      },
      {
        "point_id": "node_c:4:3952ac52",
        "text": "Diarrhea, nausea and vomiting, and abdominal pain can be symptoms.",
        "citations": [
          "doc3_covid19.txt:chunk_00001"
        ]
      },
      {
        "point_id": "node_c:5:f358d000",
        "text": "Skin rashes have been reported as a symptom of COVID-19.",
        "citations": [
          "doc3_covid19.txt:chunk_00001"
        ]
      },
      {
        "point_id": "node_c:6:67f157f1",
        "text": "Infants may experience difficulty feeding as a symptom.",
        "citations": [
          "doc3_covid19.txt:chunk_00001"
        ]
      }
    ]
  }
]